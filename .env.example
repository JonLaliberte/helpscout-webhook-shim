# Copy to .env on the Hermes box and fill with GENERATED secrets. Never commit .env.
#
#   cp .env.example .env
#   # HS_WEBHOOK_SECRET must be <=40 chars (Help Scout limit); hex-20 = 40 chars.
#   sed -i "s|^HS_WEBHOOK_SECRET=.*|HS_WEBHOOK_SECRET=$(openssl rand -hex 20)|" .env
#   # WEBHOOK_SECRET must MATCH Hermes's global WEBHOOK_SECRET in ~/.hermes/.env.
#   sed -i "s|^WEBHOOK_SECRET=.*|WEBHOOK_SECRET=$(openssl rand -hex 32)|" .env
#   chmod 600 .env

# Secret you paste into Help Scout when creating the webhook. The shim verifies
# each request's X-HelpScout-Signature against it (base64 HMAC-SHA1).
HS_WEBHOOK_SECRET=

# Hermes's global webhook secret. The shim re-signs the forwarded body with this
# (hex HMAC-SHA256). Must be identical to WEBHOOK_SECRET in ~/.hermes/.env.
WEBHOOK_SECRET=

# Hermes webhook route the shim forwards to. Default matches the config snippet
# in docs/hermes-config.yaml (route name: helpscout-tickets).
HERMES_WEBHOOK_URL=http://127.0.0.1:8644/webhooks/helpscout-tickets

# Seconds to wait on the forward to Hermes before returning 502.
FORWARD_TIMEOUT=15
